  id      String     @id @default(cuid())
  name    String
  type    EntityType
  email   String?
  phone   String?
  address String?

  metadata Json?

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id      String @id @default(cuid())
