enum RoleType {
  ADMIN_GUDANG
  KEPALA_GUDANG
  MANAGER_OPERASIONAL
  DIREKTUR
}

enum TaskStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model Role {
  id          String @id @default(cuid())
  name        RoleType @unique
  description String?

  workflowTasks WorkflowTask[]

  createdAt DateTime @default(now())
